{
  "manifest_version": 2,
  "name": "Midori Privacy",
  "version": "1.0.2",
  "description": "Built-in ad and tracker filtering for Midori.",
  "browser_specific_settings": {
    "gecko": {
      "id": "midori-privacy@astian.org"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://youtu.be/*",
        "*://*.youtu.be/*",
        "*://astiango.com/*",
        "*://*.astiango.com/*",
        "*://astian.org/*",
        "*://*.astian.org/*"
      ],
      "js": [
        "adblock_cosmetic.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
