<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         Semantic colors (Dark / Night theme overrides)
         ============================================================ -->

    <!-- App background & surfaces -->
    <color name="app_background">#FF0D1117</color>
    <color name="surface">#FF121D2B</color>
    <color name="surface_elevated">#FF1A2836</color>
    <color name="surface_card">#FF121D2B</color>

    <!-- Primary / Accent (brighter on dark for contrast) -->
    <color name="primary">#FF06E290</color>
    <color name="primary_dark">#FF04A469</color>
    <color name="primary_light">#FF2EFAAE</color>
    <color name="accent">#FF2EFAAE</color>
    <color name="on_primary">#FF0D1117</color>
    <color name="on_primary_container">#FF2EFAAE</color>

    <!-- Text -->
    <color name="text_primary">#FFFFFFFF</color>
    <color name="text_secondary">#FF8B949E</color>
    <color name="text_tertiary">#FF5A6E63</color>
    <color name="text_on_dark">#FFFFFFFF</color>

    <!-- Dividers & borders -->
    <color name="divider">#1A06E290</color>
    <color name="border">#1506E290</color>
    <color name="border_strong">#FF06E290</color>

    <!-- Toolbar -->
    <color name="toolbarBackgroundColor">@color/app_background</color>
    <color name="toolbarUrlBoxColor">#FF121D2B</color>
    <color name="toolbar_icon_color">#FF06E290</color>
    <color name="toolbar_icon_disabled">#FF5A6E63</color>
    <color name="icons">@color/toolbar_icon_color</color>
    <color name="mozac_ui_tabcounter_default_tint" tools:ignore="UnusedResources">@color/icons</color>

    <!-- Welcome / Onboarding (stays dark in both themes) -->
    <color name="welcome_background">#FF024B30</color>
    <color name="welcome_card_background">#FF036641</color>

    <!-- Tab Tray -->
    <color name="tab_tray_bg">#FF0D1117</color>
    <color name="tab_tray_bg_private">#FF0A0E12</color>
    <color name="tab_tray_card">#FF121D2B</color>
    <color name="tab_tray_card_private">#FF024B30</color>
    <color name="tab_tray_accent">#FF06E290</color>
    <color name="tab_tray_accent_private">#FF2EFAAE</color>
    <color name="tab_tray_text_primary">#FFFFFFFF</color>
    <color name="tab_tray_text_secondary">#FF8B949E</color>
    <color name="tab_tray_text_url">#FF5A6E63</color>
    <color name="tab_tray_close_bg">#44000000</color>
    <color name="tab_tray_panel_bg">#1A06E290</color>
    <color name="tab_tray_panel_selected">#FF06E290</color>
    <color name="tab_tray_panel_selected_private">#FF2EFAAE</color>
    <color name="tab_tray_selected_border">#FF06E290</color>
    <color name="tab_tray_selected_border_private">#FF2EFAAE</color>
    <color name="tab_tray_thumbnail_placeholder">#FF1A2836</color>
    <color name="tab_tray_panel_text_selected">#FF0D1117</color>
    <color name="tab_tray_panel_text_unselected">#FF8B949E</color>
    <color name="tab_tray_bottom_bg">#FF0A0E12</color>
    <color name="tab_tray_new_tab_text">#FF0D1117</color>

    <!-- Home Screen -->
    <color name="home_background">@color/app_background</color>
    <color name="home_search_bar_bg">#FF121D2B</color>
    <color name="home_card_bg">#FF121D2B</color>
    <color name="home_accent">#FF06E290</color>
    <color name="home_shortcut_icon_bg">#FF1A2836</color>

    <!-- Tab counter badge -->
    <color name="tab_counter_badge_bg">#FF06E290</color>
    <color name="tab_counter_badge_text">#FF0D1117</color>
    <color name="tab_counter_badge_border">#FF0D1117</color>

    <!-- Navigation bar -->
    <color name="nav_bar_bg">@color/app_background</color>
    <color name="nav_bar_separator">#1A06E290</color>

</resources>
