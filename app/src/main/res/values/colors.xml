<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         Midori Brand Palette (from brand guidelines)
         #024B30  #036641  #04A469  #06E290  #2EFAAE
         ============================================================ -->
    <color name="midori_green_darkest">#FF024B30</color>
    <color name="midori_green_dark">#FF036641</color>
    <color name="midori_green_primary">#FF04A469</color>
    <color name="midori_green_bright">#FF06E290</color>
    <color name="midori_green_mint">#FF2EFAAE</color>

    <!-- ============================================================
         Semantic colors (Light theme — default)
         ============================================================ -->

    <!-- App background & surfaces -->
    <color name="app_background">#FFF5FAF7</color>
    <color name="surface">#FFEBF4EF</color>
    <color name="surface_elevated">#FFFFFFFF</color>
    <color name="surface_card">#FFE5F0EA</color>

    <!-- Primary / Accent -->
    <color name="primary">#FF04A469</color>
    <color name="primary_dark">#FF036641</color>
    <color name="primary_light">#FF06E290</color>
    <color name="accent">@color/midori_green_bright</color>
    <color name="on_primary">#FFFFFFFF</color>
    <color name="on_primary_container">#FF024B30</color>

    <!-- Text -->
    <color name="text_primary">#FF0F1A14</color>
    <color name="text_secondary">#FF3D5348</color>
    <color name="text_tertiary">#FF5E7A6E</color>
    <color name="text_on_dark">#FFFFFFFF</color>

    <!-- Dividers & borders -->
    <color name="divider">#3304A469</color>
    <color name="border">#2504A469</color>
    <color name="border_strong">#FF04A469</color>

    <!-- Legacy aliases (used by Mozilla Components, don't remove) -->
    <color name="dark">#FF0D1117</color>
    <color name="evenDarker">#FF0A0E12</color>
    <color name="photonPurple50">#FF9400FF</color>
    <color name="photonDarkGrey90">#FF15141A</color>

    <!-- Toolbar -->
    <color name="toolbarBackgroundColor">@color/app_background</color>
    <color name="toolbarUrlBoxColor">#FFE0EDE5</color>
    <color name="toolbar_icon_color">#FF036641</color>
    <color name="toolbar_icon_disabled">#FF8A9E93</color>
    <color name="icons">@color/toolbar_icon_color</color>
    <color name="mozac_ui_tabcounter_default_tint" tools:ignore="UnusedResources">@color/icons</color>

    <!-- Welcome / Onboarding -->
    <color name="welcome_background">#FF024B30</color>
    <color name="welcome_card_background">#FF036641</color>
    <color name="welcome_button_background">#FF06E290</color>
    <color name="welcome_button_text">#FF024B30</color>
    <color name="welcome_text_primary">#FFFFFFFF</color>
    <color name="welcome_text_secondary">#CCFFFFFF</color>
    <color name="welcome_link_color">#FF2EFAAE</color>
    <color name="welcome_dot_active">#FFFFFFFF</color>
    <color name="welcome_dot_inactive">#66FFFFFF</color>

    <!-- Tab Tray -->
    <color name="tab_tray_bg">#FFF5F9F7</color>
    <color name="tab_tray_bg_private">#FF024B30</color>
    <color name="tab_tray_card">#FFFFFFFF</color>
    <color name="tab_tray_card_private">#FF047A4E</color>
    <color name="tab_tray_accent">#FF04A469</color>
    <color name="tab_tray_accent_private">#FF2EFAAE</color>
    <color name="tab_tray_text_primary">#FF0F1A14</color>
    <color name="tab_tray_text_secondary">#FF5A6E63</color>
    <color name="tab_tray_text_url">#FF8A9E93</color>
    <color name="tab_tray_close_bg">#22000000</color>
    <color name="tab_tray_panel_bg">#1504A469</color>
    <color name="tab_tray_panel_selected">#FF04A469</color>
    <color name="tab_tray_panel_selected_private">#FF06E290</color>
    <color name="tab_tray_selected_border">#FF04A469</color>
    <color name="tab_tray_selected_border_private">#FF2EFAAE</color>
    <color name="tab_tray_thumbnail_placeholder">#FFEAF3EE</color>
    <color name="tab_tray_panel_text_selected">#FFFFFFFF</color>
    <color name="tab_tray_panel_text_unselected">#FF5A6E63</color>
    <color name="tab_tray_bottom_bg">@color/app_background</color>
    <color name="tab_tray_new_tab_text">#FFFFFFFF</color>

    <!-- Home Screen -->
    <color name="home_background">@color/app_background</color>
    <color name="home_search_bar_bg">#FFEBF4EF</color>
    <color name="home_card_bg">#FFE8F3EC</color>
    <color name="home_accent">#FF04A469</color>
    <color name="home_shortcut_icon_bg">#FFDDEEE3</color>

    <!-- Tab counter badge -->
    <color name="tab_counter_badge_bg">#FF04A469</color>
    <color name="tab_counter_badge_text">#FFFFFFFF</color>
    <color name="tab_counter_badge_border">#FFFFFFFF</color>

    <!-- Navigation bar -->
    <color name="nav_bar_bg">@color/app_background</color>
    <color name="nav_bar_separator">#1504A469</color>

</resources>
