<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.preference.Preference
            android:key="@string/pref_key_sign_in"
            android:title="@string/sign_in"
            android:summary="@string/preferences_sign_in_summary"/>

    <androidx.preference.Preference
        android:key="@string/pref_key_pair_sign_in"
        android:title="@string/pair_sign_in"
        android:summary="@string/preferences_pair_sign_in_summary"/>

    <androidx.preference.Preference
        android:key="@string/pref_key_firefox_account"
        android:title="@string/firefox_account" />

    <androidx.preference.Preference
        android:key="@string/pref_key_privacy"
        android:title="@string/privacy"
        android:summary="@string/preferences_privacy_summary"/>

    <androidx.preference.Preference
        android:key="@string/pref_key_tor_enabled"
        android:icon="@drawable/ic_tor"
        android:title="@string/preferences_tor"
        android:summary="@string/preferences_tor_summary" />

    <androidx.preference.SwitchPreferenceCompat
        android:key="@string/pref_key_launch_external_app"
        android:defaultValue="false"
        android:title="@string/open_links_in_apps" />

    <androidx.preference.Preference
            android:key="@string/pref_key_make_default_browser"
            android:title="@string/preferences_make_default_browser"/>

    <androidx.preference.Preference
        android:key="@string/pref_key_personal_data"
        android:icon="@drawable/ic_person_data"
        android:title="@string/personal_data"
        android:summary="@string/personal_data_summary" />

    <androidx.preference.Preference
        android:key="@string/pref_key_customize"
        android:title="@string/customize_category"
        android:summary="@string/preferences_customize_summary" />


    <PreferenceCategory
        android:title="@string/mozilla_category">

        <androidx.preference.Preference
            android:key="@string/pref_key_about_page"
            android:title="@string/preferences_about_page" />

    </PreferenceCategory>

</androidx.preference.PreferenceScreen>

