<androidx.preference.PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Protection Level -->
    <PreferenceCategory
        android:title="@string/privacy_protection_category">

        <androidx.preference.ListPreference
            android:key="@string/pref_key_privacy_level"
            android:title="@string/privacy_level_title"
            android:summary="@string/privacy_level_summary"
            android:defaultValue="standard"
            android:entries="@array/privacy_level_entries"
            android:entryValues="@array/privacy_level_values" />

    </PreferenceCategory>

    <!-- Tracking Protection -->
    <PreferenceCategory
        android:title="@string/tracker_category">

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:title="@string/preferences_tracking_protection_normal"
            android:key="@string/pref_key_tracking_protection_normal"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:title="@string/preferences_tracking_protection_private"
            android:key="@string/pref_key_tracking_protection_private"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/preferences_global_privacy_control"
            android:key="@string/pref_key_global_privacy_control"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="true"
            android:title="@string/privacy_cookie_blocking"
            android:summary="@string/privacy_cookie_blocking_summary"
            android:key="@string/pref_key_cookie_blocking"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/privacy_fingerprint_protection"
            android:summary="@string/privacy_fingerprint_protection_summary"
            android:key="@string/pref_key_fingerprint_protection"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/privacy_block_redirects"
            android:summary="@string/privacy_block_redirects_summary"
            android:key="@string/pref_key_block_redirects"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/privacy_strip_tracking_params"
            android:summary="@string/privacy_strip_tracking_params_summary"
            android:key="@string/pref_key_strip_tracking_params"/>

    </PreferenceCategory>

    <!-- Advanced Privacy -->
    <PreferenceCategory
        android:title="@string/privacy_advanced_category">

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/privacy_https_only"
            android:summary="@string/privacy_https_only_summary"
            android:key="@string/pref_key_https_only"/>

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/privacy_doh"
            android:summary="@string/privacy_doh_summary"
            android:key="@string/pref_key_doh"/>

    </PreferenceCategory>

    <!-- Data & History -->
    <PreferenceCategory
        android:title="@string/privacy_data_category">

        <androidx.preference.SwitchPreferenceCompat
            android:defaultValue="false"
            android:title="@string/privacy_clear_on_exit"
            android:summary="@string/privacy_clear_on_exit_summary"
            android:key="@string/pref_key_clear_on_exit"/>
    </PreferenceCategory>

</androidx.preference.PreferenceScreen>