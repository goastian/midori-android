<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tabTrayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_tray_gradient">

    <!-- Header: back arrow + tab count title -->
    <ImageButton
        android:id="@+id/tabTrayBackButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/nav_back"
        android:scaleType="center"
        android:src="@drawable/mozac_ic_back_24"
        android:tint="@color/text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tabTrayTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:textColor="@color/tab_tray_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="3 Tabs"
        app:layout_constraintBottom_toBottomOf="@id/tabTrayBackButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tabTrayBackButton"
        app:layout_constraintTop_toTopOf="@id/tabTrayBackButton" />

    <!-- Segmented control: Normal | Private -->
    <LinearLayout
        android:id="@+id/tabPanelContainer"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_panel_container"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabTrayBackButton">

        <TextView
            android:id="@+id/tabPanelNormal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_panel_tab_selected"
            android:gravity="center"
            android:text="@string/tab_tray_normal_tabs"
            android:textColor="@color/tab_tray_panel_text_selected"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabPanelPrivate"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_panel_tab_unselected"
            android:gravity="center"
            android:text="@string/tab_tray_private_tabs"
            android:textColor="@color/tab_tray_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- RecyclerView for tabs grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tabsTray"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/tabTrayBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabPanelContainer" />

    <!-- Empty state text -->
    <TextView
        android:id="@+id/tabTrayEmptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tab_tray_empty"
        android:textColor="@color/tab_tray_text_secondary"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/tabTrayBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabPanelContainer" />

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/tabTrayBottomBar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@color/tab_tray_bottom_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Close All button -->
        <TextView
            android:id="@+id/tabTrayCloseAll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_close_all_button"
            android:drawableStart="@drawable/ic_close_all"
            android:drawablePadding="8dp"
            android:drawableTint="@color/tab_tray_text_primary"
            android:gravity="center"
            android:text="@string/tab_tray_close_all"
            android:textColor="@color/tab_tray_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Save to Collection button -->
        <ImageButton
            android:id="@+id/tabTraySaveCollection"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_close_all_button"
            android:contentDescription="@string/collection_add_tabs"
            android:scaleType="center"
            android:src="@drawable/ic_folder"
            android:tint="@color/tab_tray_text_primary" />

        <!-- New Tab button -->
        <TextView
            android:id="@+id/tabTrayNewTab"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_new_tab_button"
            android:drawableStart="@drawable/ic_add_circle"
            android:drawablePadding="8dp"
            android:drawableTint="@color/tab_tray_new_tab_text"
            android:gravity="center"
            android:text="@string/tab_tray_new_tab"
            android:textColor="@color/tab_tray_new_tab_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
